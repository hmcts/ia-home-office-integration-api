{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "hmctsReferenceNumber": {
      "type": "string",
      "pattern": "^(RP|PA|EA|HU|DC|EU|AG)/[0-9]{5}/[0-9]{4}$"
    },
    "uan": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{4}-[0-9]{4}-[0-9]{4}$"
    },
    "familyName": {
      "type": "string"
    },
    "givenNames": {
      "type": "string"
    },
    "dateOfBirth": {
      "type": "string",
      "pattern": "^(19[0-9]{2}|[2-9][0-9]{3})-(0[1-9]|1[012])-(0[1-9]|[12][0-9]|3[01])$"
    },
    "stf24weekCohorts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "included":
          {
            "type": "string"
          }
        },
        "required": [
          "name",
          "included"
        ]
      }
    },
    "timeStamp": {
      "type": "string",
      "pattern": "^(19[0-9]{2}|[2-9][0-9]{3})-(0[1-9]|1[012])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):([0-5][0-9]):([0-5][0-9])Z$"
    }
  },
  "required": [
    "hmctsReferenceNumber",
    "familyName",
    "givenNames",
    "dateOfBirth",
    "stf24weekCohorts",
    "timeStamp"
  ]
}