{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "hoClaimDate": {
    "type": "string",
    "pattern": "^(19[0-9]{2}|[2-9][0-9]{3})-(0[1-9]|1[012])-(0[1-9]|[12][0-9]|3[01])$"
    },
    "hoDecisionDate": {
    "type": "string",
    "pattern": "^(19[0-9]{2}|[2-9][0-9]{3})-(0[1-9]|1[012])-(0[1-9]|[12][0-9]|3[01])$"
    },
    "hoDecisionLetterDate": {
    "type": "string",
    "pattern": "^(19[0-9]{2}|[2-9][0-9]{3})-(0[1-9]|1[012])-(0[1-9]|[12][0-9]|3[01])$"
    },
    "appellants": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pp": {
          "type": "string",
          "pattern": "^[0-9]{2}$"
          },
          "familyName": {
          "type": "string"
          },
          "givenNames": {
          "type": "string"
          },
          "dateOfBirth": {
          "type": "string",
          "pattern": "^(19[0-9]{2}|[2-9][0-9]{3})-(0[1-9]|1[012])-(0[1-9]|[12][0-9]|3[01])$"
          },
          "nationality": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
          },
          "roa": {
          "type": "boolean"
          },
          "asylumSupport": {
          "type": "boolean"
          },
          "hoFeeWaiver": {
          "type": "boolean"
          },
          "language": {
          "type": "string",
          "pattern": "^[a-z]{3}$"
          },
          "interpreterNeeded": {
          "type": "boolean"
          }
        },
        "required": [
          "familyName",
          "givenNames",
          "dateOfBirth",
          "nationality",
          "language"
        ]
      }
    }
  },
  "required": [
    "hoClaimDate",
    "hoDecisionDate",
    "hoDecisionLetterDate",
    "appellants"
  ]
}
